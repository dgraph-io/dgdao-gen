{{- $E := .Entity.Name }}
{{- $sAlias := .SchemaAlias }}

// {{ $E }} wraps a {{ $sAlias }}.{{ $E }} record and exposes its data through
// methods. It embeds dgdao.Entity, which supplies Record, JSON marshaling,
// and validation; the backing record struct is reachable only via Record().
type {{ $E }} struct {
	dgdao.Entity[{{ $sAlias }}.{{ $E }}]
}

// New{{ $E }} constructs a {{ $E }} with a fresh, empty record struct, then
// applies the given options.
func New{{ $E }}(opts ...typed.Option[{{ $E }}]) *{{ $E }} {
	e := &{{ $E }}{Entity: dgdao.AsEntity(&{{ $sAlias }}.{{ $E }}{})}
	typed.Apply(e, opts...)
	return e
}

// New{{ $E }}WithRecord constructs a {{ $E }} backed by the given record
// struct, then applies the given options. The entity adopts r directly — no
// defensive copy, so setters mutate the caller's struct.
func New{{ $E }}WithRecord(r *{{ $sAlias }}.{{ $E }}, opts ...typed.Option[{{ $E }}]) *{{ $E }} {
	e := &{{ $E }}{Entity: dgdao.AsEntity(r)}
	typed.Apply(e, opts...)
	return e
}

// UID returns the entity's UID bookkeeping field.
func (e *{{ $E }}) UID() string { return e.Record().UID }

// SetUID sets the entity's UID bookkeeping field.
func (e *{{ $E }}) SetUID(v string) { e.Record().UID = v }

// DType returns the entity's dgraph type list.
func (e *{{ $E }}) DType() []string { return e.Record().DType }

// SetDType sets the entity's dgraph type list.
func (e *{{ $E }}) SetDType(v []string) { e.Record().DType = v }

package {{ .Name }}

{{- range .Entities }}

// RecordTypeName returns the canonical entity name for {{ .Name }}.
// This is the value dgdao.Record requires; it lets dgdao.Client
// recognize entity types via reflection-based Record dispatch.
func (*{{ .Name }}) RecordTypeName() string { return {{ printf "%q" .Name }} }

// SchemaPredicates returns the json predicate names declared on {{ .Name }},
// excluding the uid and dgraph.type bookkeeping predicates. Order matches
// source-file declaration order.
func (*{{ .Name }}) SchemaPredicates() []string {
	return []string{
	{{- range .Fields }}
		{{- if and .JSONTag (not .IsUID) (not .IsDType) }}
		{{ printf "%q" .JSONTag }},
		{{- end }}
	{{- end }}
	}
}

// SchemaSearchPredicate returns the predicate name of the entity's primary
// searchable field (the first field with a fulltext index), or empty string
// if none. Used by tooling that needs a default search target.
func (*{{ .Name }}) SchemaSearchPredicate() string { return {{ printf "%q" .SearchPredicate }} }
{{- end }}

// Models returns one zero value per schema entity type, for tooling that needs
// the full type set (e.g. migrate scaffolding and verification).
func Models() []any {
	return []any{
	{{- range .Entities }}
		&{{ .Name }}{},
	{{- end }}
	}
}

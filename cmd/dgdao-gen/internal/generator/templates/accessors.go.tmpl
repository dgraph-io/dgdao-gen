{{- $E := .Entity.Name }}
{{- $sAlias := .SchemaAlias }}

{{- $scalars := nonSliceScalarFields .Entity.Fields }}
{{- $pointerEdges := allPointerSingularEdgeFields .Entity.Fields }}
{{- $valueEdges := allValueSingularEdgeFields .Entity.Fields }}
{{- $singularViaList := allSingularViaListFields .Entity.Fields }}
{{- $multiEdges := allMultiEdgeFields .Entity.Fields }}
{{- $scalarSlices := allSliceFields .Entity.Fields }}

{{- range $scalars }}
{{- if not .IsUID }}{{- if not .IsDType }}

// {{ .Name }} returns the {{ .JSONTag }} field.
func (e *{{ $E }}) {{ .Name }}() {{ .GoType }} { return e.Record().{{ .Name }} }

// Set{{ .Name }} sets the {{ .JSONTag }} field.
func (e *{{ $E }}) Set{{ .Name }}(v {{ .GoType }}) { e.Record().{{ .Name }} = v }
{{- end }}{{- end }}
{{- end }}

{{- range $pointerEdges }}
{{- $et := trimPointerPrefix .GoType }}
{{- $bare := trimSchemaAlias $et $sAlias }}

// {{ .Name }} returns the {{ $bare }} entity, or nil if not set.
// Shared state: mutations through the returned entity write through to e.
func (e *{{ $E }}) {{ .Name }}() *{{ $bare }} {
	if e.Record().{{ .Name }} == nil {
		return nil
	}
	return &{{ $bare }}{Entity: dgdao.AsEntity(e.Record().{{ .Name }})}
}

// Set{{ .Name }} sets or clears the {{ $bare }} edge.
func (e *{{ $E }}) Set{{ .Name }}(v *{{ $bare }}) {
	if v == nil {
		e.Record().{{ .Name }} = nil
		return
	}
	e.Record().{{ .Name }} = v.Record()
}
{{- end }}

{{- range $valueEdges }}
{{- $bare := trimSchemaAlias .GoType $sAlias }}

// {{ .Name }} returns an entity over the value-typed record field. The entity
// shares state with e — mutations are visible to e immediately.
func (e *{{ $E }}) {{ .Name }}() *{{ $bare }} {
	return &{{ $bare }}{Entity: dgdao.AsEntity(&e.Record().{{ .Name }})}
}

// Set{{ .Name }} copies the value from v into the record field. Note: this is
// a value copy, so v and e.{{ .Name }}() will not share state after this call.
func (e *{{ $E }}) Set{{ .Name }}(v *{{ $bare }}) {
	if v != nil {
		e.Record().{{ .Name }} = *v.Record()
	}
}
{{- end }}

{{- range $singularViaList }}
{{- $bare := trimSliceOfPointerPrefix .GoType $sAlias }}

// {{ .Name }} returns the first element of the singular-via-list edge as an entity,
// or nil if the list is empty.
func (e *{{ $E }}) {{ .Name }}() *{{ $bare }} {
	if len(e.Record().{{ .Name }}) == 0 || e.Record().{{ .Name }}[0] == nil {
		return nil
	}
	return &{{ $bare }}{Entity: dgdao.AsEntity(e.Record().{{ .Name }}[0])}
}

// Set{{ .Name }} replaces the singular-via-list edge with v, or clears it if nil.
func (e *{{ $E }}) Set{{ .Name }}(v *{{ $bare }}) {
	if v == nil {
		e.Record().{{ .Name }} = nil
		return
	}
	e.Record().{{ .Name }} = []*{{ $sAlias }}.{{ $bare }}{v.Record()}
}
{{- end }}

{{- range $multiEdges }}
{{- $bare := trimSliceOfPointerPrefix .GoType $sAlias }}

// {{ .Name }} returns a freshly allocated slice of entities over each
// {{ $bare }} in the multi-edge.
func (e *{{ $E }}) {{ .Name }}() []*{{ $bare }} {
	out := make([]*{{ $bare }}, len(e.Record().{{ .Name }}))
	for i, x := range e.Record().{{ .Name }} {
		out[i] = &{{ $bare }}{Entity: dgdao.AsEntity(x)}
	}
	return out
}

// {{ .Name }}Seq returns an iterator over the {{ $bare }} entities, avoiding
// the allocation in {{ .Name }}().
func (e *{{ $E }}) {{ .Name }}Seq() iter.Seq[*{{ $bare }}] {
	return func(yield func(*{{ $bare }}) bool) {
		for _, x := range e.Record().{{ .Name }} {
			if !yield(&{{ $bare }}{Entity: dgdao.AsEntity(x)}) {
				return
			}
		}
	}
}

// Set{{ .Name }} replaces the multi-edge with the given items.
func (e *{{ $E }}) Set{{ .Name }}(items ...*{{ $bare }}) {
	e.Record().{{ .Name }} = make([]*{{ $sAlias }}.{{ $bare }}, len(items))
	for i, x := range items {
		e.Record().{{ .Name }}[i] = x.Record()
	}
}

// Append{{ .Name }} appends items to the multi-edge.
func (e *{{ $E }}) Append{{ .Name }}(items ...*{{ $bare }}) {
	for _, x := range items {
		e.Record().{{ .Name }} = append(e.Record().{{ .Name }}, x.Record())
	}
}

// Remove{{ .Name }} removes elements with any of the given UIDs from the multi-edge.
func (e *{{ $E }}) Remove{{ .Name }}(uids ...string) {
	e.Record().{{ .Name }} = slices.DeleteFunc(e.Record().{{ .Name }}, func(x *{{ $sAlias }}.{{ $bare }}) bool {
		return x != nil && slices.Contains(uids, x.UID)
	})
}
{{- end }}

{{- range $scalarSlices }}
{{- $et := trimSlicePrefix .GoType }}

// {{ .Name }} returns the scalar slice.
func (e *{{ $E }}) {{ .Name }}() []{{ $et }} { return e.Record().{{ .Name }} }

// Set{{ .Name }} sets the scalar slice.
func (e *{{ $E }}) Set{{ .Name }}(v []{{ $et }}) { e.Record().{{ .Name }} = v }

// Append{{ .Name }} appends values to the scalar slice.
func (e *{{ $E }}) Append{{ .Name }}(v ...{{ $et }}) {
	e.Record().{{ .Name }} = append(e.Record().{{ .Name }}, v...)
}

// Remove{{ .Name }}Func removes all elements for which fn returns true.
func (e *{{ $E }}) Remove{{ .Name }}Func(fn func({{ $et }}) bool) {
	e.Record().{{ .Name }} = slices.DeleteFunc(e.Record().{{ .Name }}, fn)
}
{{- end }}
